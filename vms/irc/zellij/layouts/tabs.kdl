layout {
    default_tab_template name="main" {
        // compact-bar at the top
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar" {
                tooltip "F1"
            }
        }
        children
    }

    tab name="tiny" cwd="~/tiny_logs" {
        pane command="proxychains4 -q tiny"
        floating_panes {
          pane {
              x "60%"
              y 0
              width "40%"
              height "95%"
          }
        }
    }
}
